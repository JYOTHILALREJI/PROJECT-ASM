// ASM — Arabian Shield Manpower
// Rewritten Prisma schema (SQLite)
// Design goals:
//   1. Explicit foreign-key relations between all related tables.
//   2. Consistent soft-delete via `deletedAt` on every data model so deletion
//      can be cascaded across tables WITHOUT ever hard-deleting rows.
//   3. Per-employee "custom current total working hours" that can be set at any
//      point in time (Employee.currentTotalWorkingHours).
// Legacy soft-delete flags (status='deleted', isHidden, isDeleted, deletedDate)
// are retained for backward compatibility with existing queries; the canonical
// soft-delete marker is now `deletedAt`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin") // "super_admin" or "admin"
  theme     String   @default("dark") // "dark" or "light"
  // Heartbeat timestamp updated periodically by the client while the app is
  // open. Used by the Admin Management page to show an online indicator.
  // A user is considered "online" if lastSeenAt is within the last 90s.
  lastSeenAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  notifications                Notification[]
  leaveRequestsCreated         LeaveRequest[]       @relation("CreatedBy")
  leaveRequestsReviewed        LeaveRequest[]       @relation("ReviewedBy")
  cancellationRequestsCreated  CancellationRequest[] @relation("RequestedBy")
  cancellationRequestsReviewed CancellationRequest[] @relation("ReviewedBy")
  warnings                     Warning[]
  fines                        Fine[]
  menuPermissions              AdminMenuPermission[]
  adminPermissions             AdminPermission[]
  attendanceVersions           AttendanceVersion[]
  activityLogs                 ActivityLog[]
}

model AdminMenuPermission {
  id        String   @id @default(cuid())
  userId    String
  menuKey   String // e.g. "employees", "sites", "attendance", "leave_requests", "cancellation_requests", "notifications"
  allowed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, menuKey])
  @@index([userId])
}

model Employee {
  id               String    @id @default(cuid())
  fullName         String
  employeeId       String    @unique
  nationality      String?
  dateOfBirth      DateTime?
  phone            String?
  email            String?
  address          String?
  emergencyContact String?
  position         String? // Legacy - kept for backward compat
  trade            String? // New: Trade (Mason, Electrician, Welder, etc.)
  joinDate         DateTime?
  companyName      String?
  passportNumber   String?
  passportStatus   String?
  idNumber         String?
  idStatus         String?
  currentSite      String? // Denormalized site NAME (kept for backward compat with existing queries)
  currentSiteId    String? // FK -> Site.id (proper relation)
  rating           Float     @default(0)
  status           String    @default("active") // "active", "deleted", "pending_deletion"
  photo            String?
  isTeamLeader     Boolean   @default(false)
  teamLeaderSiteId String? // FK -> Site.id
  isSupervisor     Boolean   @default(false)
  supervisorSiteId String? // FK -> Site.id
  role             String    @default("Standard") // "Standard", "Team Leader", "Supervisor"
  customHourlyRate Float? // Nullable - overrides standard tier rates for this employee
  hoursThreshold   Int       @default(1000) // Hours threshold for rate switching (basic vs premium)
  // Custom current total working hours — manually settable at ANY point in time.
  // Represents the employee's running cumulative total hours and can be overridden
  // by an admin whenever needed (e.g. to correct historical data).
  currentTotalWorkingHours Float   @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  deletedAt                DateTime?

  // Relations
  currentSiteRef  Site?  @relation("EmployeeCurrentSite", fields: [currentSiteId], references: [id])
  teamLeaderSite  Site?  @relation("EmployeeTeamLeaderSite", fields: [teamLeaderSiteId], references: [id])
  supervisorSite  Site?  @relation("EmployeeSupervisorSite", fields: [supervisorSiteId], references: [id])
  attendance           Attendance[]
  warnings             Warning[]
  fines                Fine[]
  leaveRequests        LeaveRequest[]
  cancellationRequests CancellationRequest[]
  uniformRegistry      UniformRegistry[]
  siteHistory          EmpCountSitePerMonth[]
  salaryRecords        SalaryRecord[]
  workingHours         TotalEmployeeWorkingHours[]
  workLogs             WorkLog[]
  advances             Advance[]

  @@index([trade])
  @@index([isTeamLeader])
  @@index([isSupervisor])
  @@index([currentSite])
  @@index([currentSiteId])
}

model Site {
  id          String   @id @default(cuid())
  name        String   @unique
  clientName  String?
  projectName String?
  projectId   String? // Free-text project ID (e.g. client's internal project code)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  deletedAt   DateTime?

  // Back-relations for the Employee -> Site FKs
  currentEmployees Employee[] @relation("EmployeeCurrentSite")
  teamLeaders      Employee[] @relation("EmployeeTeamLeaderSite")
  supervisors      Employee[] @relation("EmployeeSupervisorSite")

  employeeHistory   EmpCountSitePerMonth[]
  monthActivations  SiteMonthActivation[]
  workLogs          WorkLog[]
  salaryRecords     SalaryRecord[]
  attendanceShares  AttendanceShare[]
  attendanceVersions AttendanceVersion[]
}

model Attendance {
  id            String   @id @default(cuid())
  employeeId    String
  date          String // YYYY-MM-DD format
  status        String   @default("present") // "present", "absent", "no_site", "overtime", "not_marked"
  overtimeHours Float?
  isHidden      Boolean  @default(false) // Legacy soft-hide when employee is deleted
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([isHidden])
  @@index([deletedAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String // "request", "warning", "fine"
  read      Boolean  @default(false)
  isHidden  Boolean  @default(false) // Legacy soft-hide
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isHidden])
  @@index([deletedAt])
}

model Warning {
  id              String    @id @default(cuid())
  employeeId      String
  reason          String
  isAutoGenerated Boolean   @default(false)
  absentDates     String? // JSON string of dates
  customDate      DateTime? // Custom date if provided, otherwise createdAt is used
  isHidden        Boolean   @default(false) // Legacy soft-hide
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([employeeId])
  @@index([isHidden])
  @@index([deletedAt])
}

model Fine {
  id         String    @id @default(cuid())
  employeeId String
  reason     String
  amount     Float
  customDate DateTime? // Custom date if provided, otherwise createdAt is used
  isHidden   Boolean   @default(false) // Legacy soft-hide
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([employeeId])
  @@index([isHidden])
  @@index([deletedAt])
}

model LeaveRequest {
  id            String    @id @default(cuid())
  employeeId    String
  leaveType     String // "casual", "sick", "annual", "emergency", "marriage", "other"
  otherTypeText String? // Free-text when leaveType is "other"
  startDate     DateTime
  endDate       DateTime
  totalDays     Int
  reason        String
  status        String    @default("pending") // "pending", "approved", "rejected"
  isHidden      Boolean   @default(false) // Legacy soft-hide
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reviewedAt    DateTime?
  deletedAt     DateTime?

  employee     Employee @relation(fields: [employeeId], references: [id])
  createdById  String
  createdBy    User     @relation("CreatedBy", fields: [createdById], references: [id])
  reviewedById String?
  reviewedBy   User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
  @@index([isHidden])
  @@index([deletedAt])
}

model CancellationRequest {
  id             String    @id @default(cuid())
  employeeId     String
  reason         String?
  status         String    @default("pending") // "pending", "approved", "rejected"
  customDate     DateTime? // Custom date if provided, otherwise createdAt is used
  isHidden       Boolean   @default(false) // Legacy soft-hide
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  reviewedAt     DateTime?
  deletedAt      DateTime?

  employee      Employee @relation(fields: [employeeId], references: [id])
  requestedById String
  requestedBy   User     @relation("RequestedBy", fields: [requestedById], references: [id])
  reviewedById  String?
  reviewedBy    User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([createdAt])
  @@index([isHidden])
  @@index([deletedAt])
}

model UniformRegistry {
  id              String   @id @default(cuid())
  uniformId       Int      @unique // Auto-assigned in the POST route (max + 1)
  tokenNumber     Int
  employeeName    String
  employeeId      String
  documentType    String // "id" or "passport"
  documentNumber  String // Stored encrypted
  items           String // JSON string
  siteName        String?
  teamLeaderName  String?
  isRenewal       Boolean  @default(false)
  previousTokenId String? // reference to previous token if this is a renewal
  isDeleted       Boolean  @default(false) // Legacy soft-delete
  isHidden        Boolean  @default(false) // Legacy soft-hide
  createdAt       DateTime @default(now())
  renewalDate     DateTime // 6 months from createdAt
  deletedAt       DateTime?

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([tokenNumber])
  @@index([createdAt])
  @@index([uniformId])
  @@index([isHidden])
  @@index([deletedAt])
}

model Permission {
  id        String   @id @default(cuid())
  name      String   @unique // Display name: "Dashboard", "Employees", etc.
  slug      String   @unique // URL key: "dashboard", "employees", etc.
  group     String   @default("general") // Permission group
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  adminPermissions AdminPermission[]

  @@index([slug])
  @@index([group])
}

model AdminPermission {
  id           String   @id @default(cuid())
  adminId      String
  permissionId String
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  admin      User       @relation(fields: [adminId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([adminId, permissionId])
  @@index([adminId])
  @@index([permissionId])
}

model TotalEmployeeWorkingHours {
  id                String   @id @default(cuid())
  empId             String // FK to Employee
  empName           String
  month             String // YYYY-MM format - which month these hours belong to
  totalWorkingHours Float    @default(0) // hours for this specific month
  rtPerHour         Float    @default(2.5) // rate per hour for this month
  isCustom          Boolean  @default(false) // if true, rtPerHour is manually set
  isDeleted         Boolean  @default(false) // Legacy soft-delete
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  employee Employee @relation(fields: [empId], references: [id], onDelete: Cascade)

  @@unique([empId, month])
  @@index([empId])
  @@index([month])
  @@index([isDeleted])
  @@index([deletedAt])
}

model SalaryRecord {
  id            String   @id @default(cuid())
  empId         String // FK to Employee
  empName       String
  siteId        String // FK to Site
  siteName      String
  month         String // YYYY-MM format
  year          Int
  nationality   String   @default("")
  trade         String   @default("")
  employeeCode  String   @default("") // employeeId (e.g. ASM-001)
  slNo          Int      @default(0)
  totalHours    Float    @default(0)
  rtPerHour     Float    @default(2.5)
  totalSalary   Float    @default(0)
  deduction     Float    @default(0)
  advance       Float    @default(0)
  balanceSalary Float    @default(0)
  isPaid        Boolean  @default(false)
  isDeleted     Boolean  @default(false) // Legacy soft-delete
  rateTier      String   @default("standard") // "standard" | "premium"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  employee Employee @relation(fields: [empId], references: [id], onDelete: Cascade)
  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([empId, siteId, month, year, rateTier])
  @@index([empId])
  @@index([siteId])
  @@index([month])
  @@index([year])
  @@index([siteId, month, year])
  @@index([isPaid])
  @@index([rateTier])
  @@index([isDeleted])
  @@index([deletedAt])
}

model EmpCountSitePerMonth {
  id          String    @id @default(cuid())
  empId       String // FK to Employee
  empName     String
  siteId      String // FK to Site
  siteName    String
  month       String // YYYY-MM format
  createdDate DateTime  @default(now())
  removedDate DateTime?
  updatedDate DateTime  @updatedAt
  deletedDate DateTime? // Legacy soft-delete timestamp
  deletedAt   DateTime?

  employee Employee @relation(fields: [empId], references: [id], onDelete: Cascade)
  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([empId, siteId, month])
  @@index([empId])
  @@index([siteId])
  @@index([month])
  @@index([empId, siteId])
  @@index([deletedDate])
  @@index([deletedAt])
}

model SiteMonthActivation {
  id        String   @id @default(cuid())
  siteId    String // FK to Site
  month     String // YYYY-MM format
  year      Int
  createdAt DateTime @default(now())
  deletedAt DateTime?

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, month, year])
  @@index([month, year])
  @@index([siteId])
  @@index([deletedAt])
}

model WorkLog {
  logId        Int      @id @default(autoincrement())
  employeeId   String // FK to Employee.id
  siteId       String // FK to Site.id
  year         Int
  month        Int // 1-12
  hoursWorked  Float    @default(0.00)
  allowances   Float    @default(0.00)
  deductions   Float    @default(0.00)
  deletedAt    DateTime? // soft delete (canonical)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([employeeId, siteId, year, month])
  @@index([employeeId, year, month], name: "idx_work_logs_chrono")
}

// ---------------------------------------------------------------------------
// Advance
// ---------------------------------------------------------------------------
// An Advance is a cash payment given to an employee ahead of salary.
// It is deducted from the employee's NEXT salary record.
//
// Lifecycle:
//   1. status = "pending"  — created via the Advance bucket UI, not yet applied
//   2. status = "applied"  — applied to a salary record (advance field set)
//   3. status = "cancelled" — admin cancelled before it was applied
//
// The "appliedToSalaryRecordId" field links the advance to the salary record
// it was deducted from, for traceability.
// ---------------------------------------------------------------------------
model Advance {
  id            String   @id @default(cuid())
  empId         String // FK to Employee.id
  empName       String
  employeeCode  String   @default("") // employee.employeeId (e.g. ASM-001)
  amount        Float    @default(0)
  reason        String   @default("")
  // Status: pending (not yet applied), applied (deducted from salary),
  //         cancelled (admin voided before applying)
  status        String   @default("pending")
  // Effective month/year: which salary month this advance should be deducted from.
  // Format: month = "YYYY-MM", year = integer.
  // Default: next month from creation date.
  effectiveMonth String  // YYYY-MM
  effectiveYear  Int
  // If applied, link to the salary record it was deducted from
  appliedToSalaryRecordId String?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  employee Employee @relation(fields: [empId], references: [id], onDelete: Cascade)

  @@index([empId])
  @@index([status])
  @@index([effectiveMonth, effectiveYear])
  @@index([effectiveYear])
  @@index([deletedAt])
}

// ---------------------------------------------------------------------------
// AttendanceShare
// ---------------------------------------------------------------------------
// A shareable, auth-free link that lets a Team Leader / Supervisor mark
// attendance for a single site on a single date.
//
// Lifecycle:
//   - status = "open"     : link is active and waiting for submission
//   - status = "submitted": attendance has been recorded via this link,
//                           further edits are blocked
//   - status = "expired"  : admin manually closed the link (no submission)
//
// The token is unguessable (cuid) and tied to a single site + date.
// Once submitted, the same link returns a "submitted" view-only page so
// the TL/Supervisor can confirm their entries were saved.
// ---------------------------------------------------------------------------
model AttendanceShare {
  id          String   @id @default(cuid())
  token       String   @unique // The unguessable share token (used in URL)
  siteId      String   // FK to Site.id
  siteName    String   // Denormalized for display
  clientName  String?  // Denormalized for the attendance sheet header
  projectName String?  // Denormalized for the attendance sheet header
  // The date the attendance is for (YYYY-MM-DD). The TL marks who was
  // present/absent on this specific date.
  date        String   // YYYY-MM-DD
  // Status: open (waiting), submitted (saved), expired (admin voided)
  status      String   @default("open")
  // When submitted, snapshot of what was marked (JSON array of
  // { employeeId, status } for audit / re-display).
  submittedSnapshot String?
  submittedById   String? // Employee.id of the TL/Sup who submitted (optional)
  submittedByName String? // Denormalized name
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  expiresAt   DateTime? // Optional expiry timestamp

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@index([date])
  @@index([status])
  @@index([token])
}

// ---------------------------------------------------------------------------
// AttendanceVersion
// ---------------------------------------------------------------------------
// A snapshot of the attendance for a single site on a single date, captured
// every time attendance is written (from the website, the public share link,
// or the bulk-mark route). Each version is immutable once written.
//
// Versions are linked to a share token when the change came in via a share
// link (so the Attendance Copy page can show per-link history). When the
// change came from the website admin UI, shareTokenId is null and source
// is 'website'.
//
// The Attendance Copy page lists all versions for a given site+date and
// lets the admin switch between them — switching does NOT change the live
// attendance; it just re-displays that version's snapshot. The admin can
// "Restore" a version, which writes a new version that copies the snapshot
// and updates the live attendance to match.
// ---------------------------------------------------------------------------
model AttendanceVersion {
  id           String   @id @default(cuid())
  siteId       String   // FK to Site.id
  siteName     String   // Denormalized
  date         String   // YYYY-MM-DD
  // The version number for this site+date. v1 is the first capture, v2 the
  // next, etc. Computed at write time by counting existing versions + 1.
  versionNumber Int
  // JSON snapshot of every employee's status at capture time:
  //   [{ "employeeId": "...", "fullName": "...", "employeeCode": "...",
  //      "status": "present" | "absent" | "no_site" | "overtime" | "not_marked",
  //      "overtimeHours": number | null }]
  snapshot     String
  // Where the change came from:
  //   - 'website'    : admin marked via the Attendance page
  //   - 'share_link' : TL/Supervisor submitted via /attendance/share/<token>
  //   - 'bulk_mark'  : admin used bulk-mark-present
  //   - 'restore'    : admin restored a previous version
  source       String   @default("website")
  // If source is 'share_link', the token of the share that submitted it.
  shareToken   String?
  // Who made the change (User.id for website/restore, or the submittedByName
  // for share_link). Stored as a free-text label for audit + the User.id
  // when known for the relation.
  changedById   String?
  changedByName String?
  // Brief label shown in the version history UI, e.g.
  //   "Marked 12 present, 3 absent via share link"
  summary      String
  createdAt    DateTime @default(now())

  site  Site?  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@unique([siteId, date, versionNumber])
  @@index([siteId, date])
  @@index([date])
  @@index([shareToken])
  @@index([changedById])
}

// ---------------------------------------------------------------------------
// ActivityLog
// ---------------------------------------------------------------------------
// A universal audit log. Every mutating action (create/update/delete) on any
// data in the app is recorded here with:
//   - who did it (userId + displayName — name if set, else email)
//   - what they did (action: create/update/delete/login/etc.)
//   - which entity was affected (entityType + entityId)
//   - a human-readable description (e.g. "Marked John Doe as present")
//   - a JSON snapshot of relevant details (optional, for context)
//   - timestamp
//
// The All Logs sidebar page groups these by user so an admin can see, per
// account holder, every activity they performed.
// ---------------------------------------------------------------------------
model ActivityLog {
  id           String   @id @default(cuid())
  // Who performed the action. userId may be null for system-generated actions
  // (e.g. auto-warnings) — in that case actorType is 'system'.
  userId       String?
  // Display name shown in the UI — prefers User.name, falls back to email.
  // Stored denormalized so the log still reads correctly even if the user is
  // later deleted.
  displayName  String
  actorType    String   @default("user") // "user" | "system"
  // What they did, e.g. "create", "update", "delete", "mark_attendance",
  // "bulk_mark", "share_link_submit", "login", "advance_create", etc.
  action       String
  // Which entity was affected, e.g. "employee", "site", "attendance",
  // "salary_record", "advance", "attendance_share", "user", etc.
  entityType   String
  entityId     String?
  entityName   String?  // Human-readable name of the affected entity
  // Human-readable summary, e.g. "Marked John Doe as present for 2026-07-15"
  description  String
  // Optional JSON details for context (before/after values, etc.)
  details      String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@index([entityType, entityId])
}
